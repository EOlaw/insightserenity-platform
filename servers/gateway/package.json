{
  "name": "@insightserenity/gateway",
  "version": "1.0.0",
  "description": "API Gateway server for InsightSerenity Platform - Routes and manages traffic between microservices",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:unit": "npm run test -- --testPathPattern=tests/unit",
    "test:integration": "npm run test -- --testPathPattern=tests/integration",
    "test:coverage": "npm run test -- --coverage",
    "test:watch": "npm run test -- --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "validate": "npm run lint && npm run test:unit",
    "build": "npm run validate",
    "security:check": "npm audit --audit-level=high",
    "health:check": "curl -f http://localhost:3000/health || exit 1",
    "routes:list": "node scripts/list-routes.js",
    "config:validate": "node scripts/validate-gateway-config.js"
  },
  "dependencies": {
    "@insightserenity/shared": "*",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.6.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "node-circuit-breaker": "^0.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^4.6.11",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "cross-env": "^10.0.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.1",
    "eslint-plugin-security": "^2.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insightserenity/platform.git",
    "directory": "servers/gateway"
  },
  "keywords": [
    "gateway",
    "api-gateway",
    "microservices",
    "proxy",
    "routing",
    "load-balancer",
    "enterprise",
    "multi-tenant",
    "authentication",
    "rate-limiting"
  ],
  "author": "InsightSerenity Platform Team",
  "license": "PROPRIETARY",
  "bugs": {
    "url": "https://github.com/insightserenity/platform/issues"
  },
  "homepage": "https://github.com/insightserenity/platform/tree/main/servers/gateway#readme"
}