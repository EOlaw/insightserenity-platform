{
    "name": "@insightserenity/api-gateway",
    "author": "InsightSerenity Platform Team",
    "license": "PROPRIETARY",
    "version": "1.0.0",
    "description": "Enterprise API Gateway for InsightSerenity Platform - Routes and manages traffic between microservices",
    "main": "server.js",
    "private": true,
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "start:dev": "cross-env NODE_ENV=development nodemon server.js",
        "start:prod": "cross-env NODE_ENV=production node server.js",
        "start:cluster": "cross-env NODE_ENV=production GATEWAY_WORKERS=4 node server.js",
        "test": "jest --coverage --detectOpenHandles",
        "test:watch": "jest --watch",
        "test:integration": "jest --testPathPattern=test/integration --detectOpenHandles",
        "test:load": "artillery run test/load/gateway-load-test.yml",
        "lint": "eslint . --ext .js",
        "lint:fix": "eslint . --ext .js --fix",
        "docs": "jsdoc -c jsdoc.config.json",
        "docker:build": "docker build -t insightserenity-gateway .",
        "docker:run": "docker run -p 3000:3000 --env-file .env insightserenity-gateway",
        "format": "prettier --write \"**/*.{js,json,md}\"",
        "validate": "npm run lint && npm run test:unit",
        "validate:config": "node scripts/validate-config.js",
        "generate:docs": "node scripts/generate-api-docs.js",
        "build": "npm run validate",
        "security:check": "npm audit --audit-level=high",
        "security:scan": "npm audit && eslint . --ext .js --rule security/detect-unsafe-regex:error",
        "test:security": "jest --testPathPattern=security --coverage",
        "validate:routes": "node scripts/validate-routes-security.js",
        "health:check": "curl -f http://localhost:3000/health || node scripts/health-checks.js || exit 1",
        "metrics": "node scripts/metrics-exporter.js",
        "routes:list": "node scripts/list-routes.js",
        "config:validate": "node scripts/validate-gateway-config.js",
        "metrics:export": "node scripts/export-metrics.js"
    },
    "dependencies": {
        "@insightserenity/shared": "*",
        "@opentelemetry/api": "^1.7.0",
        "@opentelemetry/auto-instrumentations-node": "^0.40.3",
        "@opentelemetry/core": "^1.18.1",
        "@opentelemetry/exporter-jaeger": "^2.0.1",
        "@opentelemetry/exporter-prometheus": "^0.203.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.45.1",
        "@opentelemetry/instrumentation-express": "^0.34.1",
        "@opentelemetry/instrumentation-http": "^0.45.1",
        "@opentelemetry/resources": "^1.18.1",
        "@opentelemetry/sdk-node": "^0.45.1",
        "@opentelemetry/semantic-conventions": "^1.18.1",
        "async": "^3.2.5",
        "axios": "^1.11.0",
        "bluebird": "^3.7.2",
        "body-parser": "^1.20.2",
        "bottleneck": "^2.19.5",
        "cache-manager": "^7.1.1",
        "cache-manager-redis-store": "^3.0.1",
        "circuit-breaker-js": "^0.0.1",
        "compression": "^1.7.4",
        "connect-redis": "^7.1.0",
        "constants": "^0.0.2",
        "consul": "^1.2.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "etcd3": "^1.1.2",
        "events": "^1.1.1",
        "express": "^4.18.2",
        "express-async-handler": "^1.2.0",
        "express-fileupload": "^1.4.3",
        "express-fingerprint": "^1.0.5",
        "express-http-proxy": "^2.0.0",
        "express-rate-limit": "^7.1.5",
        "express-session": "^1.17.3",
        "express-slow-down": "^3.0.0",
        "express-useragent": "^1.0.15",
        "express-validator": "^7.0.1",
        "express-winston": "^4.2.0",
        "helmet": "^7.1.0",
        "http-proxy": "^1.18.1",
        "http-proxy-middleware": "^2.0.6",
        "ioredis": "^5.7.0",
        "joi": "^17.11.0",
        "jsonpath": "^1.1.1",
        "jsonwebtoken": "^9.0.2",
        "lodash": "^4.17.21",
        "lru-cache": "^11.1.0",
        "method-override": "^3.0.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cache": "^5.1.2",
        "node-schedule": "^2.1.1",
        "opossum": "^8.5.0",
        "p-queue": "^7.4.1",
        "perf_hooks": "^0.0.1",
        "prom-client": "^15.1.3",
        "redis": "^4.6.10",
        "response-time": "^2.3.2",
        "retry": "^0.13.1",
        "serve-static": "^1.15.0",
        "socket.io": "^4.5.4",
        "socket.io-client": "^4.5.4",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "util": "^0.12.5",
        "uuid": "^9.0.1",
        "winston": "^3.11.0",
        "winston-daily-rotate-file": "^5.0.0",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "@types/jest": "^29.5.10",
        "artillery-plugin-expect": "^2.0.1",
        "cross-env": "^10.0.0",
        "eslint": "^8.54.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.0",
        "eslint-plugin-jest": "^27.6.0",
        "jest": "^29.7.0",
        "mock-redis": "^0.0.3",
        "nock": "^13.4.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "sinon": "^17.0.1",
        "supertest": "^6.3.3"
    },
    "keywords": [
        "api-gateway",
        "microservices",
        "proxy",
        "load-balancer",
        "circuit-breaker",
        "rate-limiting",
        "authentication",
        "multi-tenant"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/insightserenity/platform.git",
        "directory": "servers/gateway"
    },
    "bugs": {
        "url": "https://github.com/insightserenity/platform/issues"
    },
    "homepage": "https://github.com/insightserenity/platform/tree/main/servers/gateway#readme"
}
