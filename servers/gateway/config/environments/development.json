{
  "environment": "development",
  "server": {
    "port": 8080,
    "host": "0.0.0.0",
    "protocol": "http",
    "cluster": {
      "enabled": false,
      "workers": 1
    },
    "cors": {
      "enabled": true,
      "origins": ["http://localhost:3000", "http://localhost:3001", "http://localhost:4001", "http://localhost:4002"],
      "credentials": true,
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "allowedHeaders": ["Content-Type", "Authorization", "X-Requested-With", "X-Tenant-ID", "X-API-Key"],
      "exposedHeaders": ["X-Total-Count", "X-Page-Count", "X-Request-ID"],
      "maxAge": 86400
    },
    "compression": {
      "enabled": true,
      "level": 6,
      "threshold": 1024,
      "filter": ["text/html", "text/css", "application/json", "application/javascript"]
    },
    "timeout": {
      "server": 120000,
      "socket": 125000,
      "keepAlive": 5000,
      "headersTimeout": 60000
    }
  },
  "gateway": {
    "name": "InsightSerenity-Gateway-Dev",
    "version": "1.0.0",
    "description": "API Gateway Development Instance",
    "baseUrl": "http://localhost:8080",
    "apiPrefix": "/api",
    "healthCheckPath": "/health",
    "metricsPath": "/metrics",
    "docsPath": "/docs",
    "maintenanceMode": false,
    "gracefulShutdown": {
      "enabled": true,
      "timeout": 30000,
      "forceTimeout": 60000
    }
  },
  "services": {
    "discovery": {
      "enabled": false,
      "provider": "static",
      "refreshInterval": 30000
    },
    "registry": [
      {
        "name": "admin-server",
        "url": "http://localhost:4001",
        "path": "/admin",
        "healthPath": "/health",
        "weight": 1,
        "version": "v1",
        "timeout": 30000,
        "retries": 3,
        "requiresAuth": true,
        "autoRoute": false
      },
      {
        "name": "customer-services",
        "url": "http://localhost:4002",
        "path": "/services",
        "healthPath": "/health",
        "weight": 1,
        "version": "v1",
        "timeout": 30000,
        "retries": 3,
        "requiresAuth": true,
        "autoRoute": false,
        "supportsWebSocket": true
      }
    ]
  },
  "routing": {
    "defaultAlgorithm": "round-robin",
    "fallbackAlgorithm": "random",
    "sessionAffinity": {
      "enabled": false,
      "cookieName": "SERVERID",
      "timeout": 3600000
    },
    "rules": []
  },
  "security": {
    "enabled": true,
    "helmet": {
      "enabled": true,
      "contentSecurityPolicy": false,
      "crossOriginEmbedderPolicy": false
    },
    "authentication": {
      "required": true,
      "jwt": {
        "enabled": true,
        "secret": "829a6a55aaec80f9d4b7f01b0d94643df6184853915e661d3c28f612e53dec424cbeba3df14b9de2ee6dd5d6f60d436e9c9eb59204a6852cf8e8ab2b4bfc532a",
        "algorithms": ["RS256"],
        "issuer": "insightserenity",
        "audience": "insightserenity-api",
        "expiresIn": "24h",
        "refreshExpiresIn": "7d",
        "clockTolerance": 30
      },
      "apiKey": {
        "enabled": true,
        "header": "X-API-Key",
        "query": "api_key"
      }
    },
    "encryption": {
      "algorithm": "aes-256-gcm",
      "key": "dev-encryption-key-32-bytes-long",
      "saltRounds": 10
    },
    "csrf": {
      "enabled": false,
      "cookie": false,
      "ignoreMethods": ["GET", "HEAD", "OPTIONS"]
    },
    "trustProxy": true,
    "ipWhitelist": [],
    "ipBlacklist": [],
    "ipFiltering": {
      "enabled": false
    },
    "securityHeaders": {
      "enabled": true,
      "xFrameOptions": "DENY",
      "xContentTypeOptions": "nosniff",
      "xXssProtection": "1; mode=block",
      "strictTransportSecurity": false,
      "referrerPolicy": "strict-origin-when-cross-origin"
    }
  },
  "rateLimit": {
    "enabled": true,
    "global": {
      "windowMs": 60000,
      "max": 1000,
      "message": "Too many requests from this IP, please try again later.",
      "standardHeaders": true,
      "legacyHeaders": false
    },
    "api": {
      "windowMs": 60000,
      "max": 500
    },
    "auth": {
      "windowMs": 300000,
      "max": 10
    },
    "skipSuccessfulRequests": false,
    "skipFailedRequests": false,
    "keyGenerator": "ip",
    "store": "memory"
  },
  "cache": {
    "enabled": true,
    "type": "memory",
    "defaultTTL": 300000,
    "maxSize": 104857600,
    "checkPeriod": 60000,
    "redis": {
      "enabled": false,
      "host": "localhost",
      "port": 6379,
      "password": "",
      "db": 0,
      "keyPrefix": "gateway:dev:",
      "enableOfflineQueue": false,
      "connectTimeout": 5000,
      "maxRetriesPerRequest": 1,
      "lazyConnect": true
    },
    "memory": {
      "max": 1000,
      "ttl": 300,
      "updateAgeOnGet": true
    },
    "strategies": {
      "default": "cache-first",
      "api": "network-first",
      "static": "cache-only",
      "writeThrough": true,
      "writeBehind": false,
      "refreshAhead": false
    },
    "compression": {
      "enabled": false,
      "threshold": 1024
    },
    "circuitBreaker": {
      "enabled": true,
      "threshold": 3,
      "timeout": 30000,
      "halfOpenMaxCalls": 3
    }
  },
  "monitoring": {
    "enabled": true,
    "metrics": {
      "enabled": true,
      "interval": 10000,
      "detailed": true,
      "includeSystemMetrics": true
    },
    "health": {
      "enabled": true,
      "interval": 30000,
      "timeout": 5000,
      "indicators": {
        "database": false,
        "redis": false,
        "services": true,
        "disk": true,
        "memory": true
      }
    },
    "tracing": {
      "enabled": false,
      "serviceName": "api-gateway-dev",
      "jaeger": {
        "host": "localhost",
        "port": 6831,
        "samplingRate": 1.0,
        "logSpans": false
      }
    },
    "logging": {
      "level": "debug",
      "format": "json",
      "prettyPrint": true,
      "colorize": true,
      "timestamp": true,
      "destination": "console",
      "file": {
        "enabled": false,
        "path": "./logs/dev",
        "filename": "gateway-dev.log",
        "maxSize": "10m",
        "maxFiles": "5d",
        "compress": false
      },
      "elasticsearch": {
        "enabled": false,
        "node": "http://localhost:9200",
        "index": "gateway-logs-dev"
      }
    },
    "alerts": {
      "enabled": false
    }
  },
  "database": {
    "mongodb": {
      "uri": "mongodb://localhost:27017/insightserenity_dev",
      "options": {
        "useNewUrlParser": true,
        "useUnifiedTopology": true,
        "maxPoolSize": 5,
        "minPoolSize": 1,
        "maxIdleTimeMS": 10000,
        "serverSelectionTimeoutMS": 5000,
        "socketTimeoutMS": 45000,
        "family": 4
      }
    }
  },
  "queue": {
    "enabled": false,
    "provider": "memory",
    "redis": {
      "enabled": false,
      "host": "localhost",
      "port": 6379,
      "password": "",
      "db": 1
    },
    "options": {
      "removeOnComplete": true,
      "removeOnFail": false,
      "attempts": 3,
      "backoff": {
        "type": "exponential",
        "delay": 2000
      }
    }
  },
  "circuitBreaker": {
    "enabled": true,
    "defaultConfig": {
      "failureThreshold": 5,
      "successThreshold": 2,
      "timeout": 10000,
      "resetTimeout": 30000,
      "volumeThreshold": 10,
      "errorThresholdPercentage": 50
    }
  },
  "proxy": {
    "timeout": 30000,
    "retries": 3,
    "retryDelay": 1000,
    "changeOrigin": true,
    "ws": true,
    "xfwd": true,
    "secure": false,
    "preserveHeaderKeyCase": false,
    "followRedirects": false,
    "selfHandleResponse": false
  },
  "features": {
    "multiTenancy": true,
    "apiVersioning": true,
    "graphql": false,
    "websockets": true,
    "fileUploads": true,
    "swagger": true,
    "compression": true,
    "etag": true,
    "requestId": true,
    "correlationId": true,
    "responseTime": true
  },
  "tenant": {
    "enabled": true,
    "strategy": "header",
    "headerName": "X-Tenant-ID",
    "validation": {
      "enabled": true,
      "cache": true,
      "cacheTTL": 300000
    },
    "isolation": {
      "database": false,
      "cache": true,
      "queue": false
    }
  },
  "limits": {
    "maxRequestSize": "10mb",
    "maxUploadSize": "50mb",
    "maxConnections": 1000,
    "maxConcurrentRequests": 100,
    "requestTimeout": 30000,
    "keepAliveTimeout": 5000,
    "headersTimeout": 60000,
    "maxHeaderSize": 8192,
    "maxUrlLength": 2048
  },
  "performance": {
    "clustering": false,
    "workers": 1,
    "workerRestartDelay": 1000,
    "workerMaxRestarts": 10,
    "compression": true,
    "caching": true,
    "pooling": {
      "enabled": true,
      "min": 1,
      "max": 5,
      "idleTimeoutMillis": 30000
    }
  },
  "experimental": {
    "http2": false,
    "quic": false,
    "brotli": false,
    "avif": false,
    "earlyHints": false,
    "serverTiming": true
  }
}