{
  "name": "@insightserenity-platform/admin-server",
  "version": "3.0.0",
  "description": "InsightSerenity Platform Administration Server - Enterprise management and monitoring",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "dev:debug": "cross-env NODE_ENV=development nodemon --inspect server.js",
    "test": "NODE_ENV=test jest --runInBand --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage --runInBand",
    "test:integration": "NODE_ENV=test jest --testPathPattern=integration --runInBand",
    "test:unit": "NODE_ENV=test jest --testPathPattern=unit",
    "test:e2e": "NODE_ENV=test jest --testPathPattern=e2e --runInBand",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "validate": "npm run lint && npm run test:unit",
    "build": "npm run validate",
    "security:check": "npm audit --audit-level=high",
    "db:migrate": "cross-env NODE_ENV=development node ../../tools/migration/migrate.js",
    "db:rollback": "cross-env NODE_ENV=development node ../../tools/migration/rollback.js",
    "db:seed": "cross-env NODE_ENV=development node ../../tools/migration/seed.js",
    "health:check": "curl -f http://127.0.0.1:5001/health || exit 1"
  },
  "dependencies": {
    "@eslint/plugin-kit": "^0.3.4",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "events": "^3.3.0",
    "express": "^4.18.2",
    "express-flash": "^0.0.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "redis": "^4.6.11",
    "speakeasy": "^2.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "cross-env": "^10.0.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.1",
    "eslint-plugin-security": "^2.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insightserenity/platform.git",
    "directory": "servers/admin-server"
  },
  "keywords": [
    "admin",
    "platform",
    "management",
    "enterprise",
    "multi-tenant",
    "monitoring",
    "security"
  ],
  "author": "InsightSerenity Platform Team",
  "license": "PROPRIETARY",
  "bugs": {
    "url": "https://github.com/insightserenity/platform/issues"
  },
  "homepage": "https://github.com/insightserenity/platform/tree/main/servers/admin-server#readme"
}