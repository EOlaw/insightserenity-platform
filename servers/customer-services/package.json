{
  "name": "@insightserenity/customer-services",
  "version": "1.0.0",
  "description": "Customer-facing services server for InsightSerenity Platform",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:unit": "npm run test -- --testPathPattern=tests/unit",
    "test:integration": "npm run test -- --testPathPattern=tests/integration",
    "test:coverage": "npm run test -- --coverage",
    "test:watch": "npm run test -- --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "validate": "npm run lint && npm run test:unit",
    "build": "npm run validate",
    "security:check": "npm audit --audit-level=high",
    "db:seed": "NODE_ENV=development node ../../scripts/seed-customer-data.js",
    "db:migrate": "NODE_ENV=development node ../../scripts/run-migrations.js --server=services",
    "db:rollback": "NODE_ENV=development node ../../scripts/rollback-migrations.js --server=services",
    "health:check": "curl -f http://localhost:5001/health || exit 1"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.1.1",
    "@insightserenity/shared": "*",
    "archiver": "^7.0.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-flash": "^0.0.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "fuse.js": "^7.1.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.6.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "redis": "^4.6.11",
    "socket.io": "^4.7.4",
    "stripe": "^18.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "cross-env": "^10.0.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.6.1",
    "eslint-plugin-security": "^2.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insightserenity/platform.git",
    "directory": "servers/customer-services"
  },
  "keywords": [
    "customer-services",
    "api",
    "platform",
    "enterprise",
    "multi-tenant",
    "consulting",
    "recruitment",
    "crm"
  ],
  "author": "InsightSerenity Platform Team",
  "license": "PROPRIETARY",
  "bugs": {
    "url": "https://github.com/insightserenity/platform/issues"
  },
  "homepage": "https://github.com/insightserenity/platform/tree/main/servers/customer-services#readme"
}
