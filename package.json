{
  "name": "insightserenity-platform",
  "version": "3.0.0",
  "private": true,
  "description": "Enterprise consulting platform with multi-tenant architecture",
  "author": "InsightSerenity Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "workspaces": [
    "shared",
    "servers/admin-server",
    "servers/customer-services",
    "servers/gateway",
    "tools/*"
  ],
  "scripts": {
    "prestart": "npm run validate:env",
    "start": "concurrently \"npm run start:admin\" \"npm run start:services\"",
    "start:admin": "npm run start --workspace=servers/admin-server",
    "start:services": "npm run start --workspace=servers/customer-services",
    "start:gateway": "npm run start --workspace=servers/gateway",
    "dev": "concurrently \"npm run dev:admin\" \"npm run dev:services\"",
    "dev:admin": "npm run dev --workspace=servers/admin-server",
    "dev:services": "npm run dev --workspace=servers/customer-services",
    "dev:gateway": "npm run dev --workspace=servers/gateway",
    "dev:shared": "npm run dev --workspace=shared",
    "dev:all": "concurrently \"npm run dev:admin\" \"npm run dev:services\" \"npm run dev:gateway\"",
    "build": "npm run build:shared && npm run build:servers",
    "build:shared": "npm run build --workspace=shared",
    "build:servers": "npm run build --workspace=servers/admin-server && npm run build --workspace=servers/customer-services",
    "build:admin": "npm run build --workspace=servers/admin-server",
    "build:services": "npm run build --workspace=servers/customer-services",
    "build:gateway": "npm run build --workspace=servers/gateway",
    "build:docker": "npm run docker:build:admin && npm run docker:build:services",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "validate:env": "node scripts/validate-environment.js",
    "security:audit": "npm audit --workspaces",
    "security:fix": "npm audit fix --workspaces",
    "security:check": "npm run security:audit && npm run security:snyk",
    "security:snyk": "snyk test",
    "fix-imports": "node tools/module-resolver.js",
    "fix-imports:auto": "node tools/module-resolver.js --fix",
    "show-modules": "node tools/module-resolver.js --map",
    "db:migrate": "node tools/migration/migrate.js",
    "db:migrate:rollback": "node tools/migration/rollback.js",
    "db:seed": "node tools/migration/seed.js",
    "db:reset": "npm run db:migrate:rollback && npm run db:migrate && npm run db:seed",
    "db:backup": "bash scripts/backup-database.sh",
    "db:restore": "bash scripts/restore-database.sh",
    "docker:build": "npm run docker:build:admin && npm run docker:build:services",
    "docker:build:admin": "docker build -f servers/admin-server/Dockerfile -t insightserenity/admin-server .",
    "docker:build:services": "docker build -f servers/customer-services/Dockerfile -t insightserenity/customer-services .",
    "docker:build:gateway": "docker build -f servers/gateway/Dockerfile -t insightserenity/gateway .",
    "docker:run": "docker-compose up",
    "docker:run:dev": "docker-compose -f docker-compose.yml -f docker-compose.override.yml up",
    "docker:run:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:stop": "docker-compose down",
    "docker:clean": "docker-compose down --volumes --remove-orphans && docker system prune -f",
    "k8s:deploy": "kubectl apply -f kubernetes/",
    "k8s:deploy:dev": "kubectl apply -f kubernetes/ --context=development",
    "k8s:deploy:staging": "kubectl apply -f kubernetes/ --context=staging",
    "k8s:deploy:prod": "kubectl apply -f kubernetes/ --context=production",
    "k8s:rollback": "kubectl rollout undo deployment",
    "k8s:status": "kubectl get pods,services,deployments",
    "terraform:init": "cd infrastructure/terraform && terraform init",
    "terraform:plan": "cd infrastructure/terraform && terraform plan",
    "terraform:apply": "cd infrastructure/terraform && terraform apply",
    "terraform:destroy": "cd infrastructure/terraform && terraform destroy",
    "deploy": "npm run deploy:staging",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:rollback": "bash scripts/rollback-deployment.sh",
    "health:check": "node tools/health-checker.js",
    "health:check:admin": "curl -f http://localhost:3001/health || exit 1",
    "health:check:services": "curl -f http://localhost:5001/health || exit 1",
    "logs": "npm run logs:admin && npm run logs:services",
    "logs:admin": "npm run logs --workspace=servers/admin-server",
    "logs:services": "npm run logs --workspace=servers/customer-services",
    "logs:tail": "tail -f logs/*.log",
    "monitor": "node tools/monitoring/performance-monitor.js",
    "monitor:logs": "node tools/monitoring/log-analyzer.js",
    "setup": "npm install && npm run build:shared && npm run db:migrate && npm run db:seed",
    "setup:dev": "npm install && npm run validate:env && npm run build:shared",
    "setup:prod": "npm ci --only=production && npm run build && npm run db:migrate",
    "clean": "npm run clean --workspaces --if-present",
    "clean:all": "npm run clean && rm -rf node_modules && rm -rf */node_modules && rm -rf */*/node_modules",
    "clean:logs": "rm -rf logs/*.log",
    "clean:cache": "npm cache clean --force",
    "clean:docker": "npm run docker:clean",
    "release": "npm run validate && npm run build && npm version",
    "release:patch": "npm run release patch",
    "release:minor": "npm run release minor",
    "release:major": "npm run release major",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "docs:generate": "jsdoc -c jsdoc.config.json",
    "docs:serve": "http-server docs/generated -p 8080",
    "compliance:report": "node tools/compliance/generate-report.js",
    "compliance:audit": "node tools/compliance/audit-checker.js",
    "performance:test": "node tools/performance/load-test.js",
    "performance:profile": "node --prof tools/performance/profile.js",
    "backup": "npm run db:backup && npm run backup:files",
    "backup:files": "bash scripts/backup-files.sh",
    "restore": "npm run db:restore && npm run restore:files",
    "restore:files": "bash scripts/restore-files.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.859.0",
    "@aws-sdk/lib-storage": "^3.859.0",
    "@aws-sdk/s3-request-presigner": "^3.859.0",
    "@azure/identity": "^4.10.2",
    "@azure/storage-blob": "^12.28.0",
    "@google-cloud/storage": "^7.16.0",
    "fs-extra": "^11.3.0",
    "joi": "^18.0.0",
    "js-yaml": "^4.1.0",
    "next": "15.4.2",
    "node-cron": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "systeminformation": "^5.27.7",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.2.2",
    "conventional-changelog-cli": "^4.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.15.0",
    "eslint-config-next": "15.4.2",
    "glob": "^10.3.10",
    "http-server": "^14.1.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.2",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "snyk": "^1.1266.0",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/insightserenity/platform.git"
  },
  "bugs": {
    "url": "https://github.com/insightserenity/platform/issues"
  },
  "homepage": "https://github.com/insightserenity/platform#readme",
  "keywords": [
    "consulting",
    "enterprise",
    "multi-tenant",
    "recruitment",
    "saas",
    "platform"
  ],
  "config": {
    "unsafe-perm": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run validate",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "volta": {
    "node": "18.19.0",
    "npm": "10.2.3"
  },
  "overrides": {
    "semver": "^7.5.4"
  }
}
